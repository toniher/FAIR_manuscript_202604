@startuml
scale 800 width
scale 300 height

left to right direction
skinparam packageStyle rectangle

skinparam usecase {
  BorderColor black
  FontSize 13
  BackgroundColor white
}

actor Trainer
actor Trainer2
actor Trainee

rectangle "Minimum steps to make FAIR training materials\nbased on community experience" {

(Develop training materials) as START

(Make Findable) as F_MAIN #d0e2ff
(Make Accessible) as A_MAIN #d9f2d9
(Make Interoperable) as I_MAIN #fff4cc
(Make Reusable) as R_MAIN #f8d7da

START --> F_MAIN
F_MAIN --> A_MAIN
A_MAIN --> I_MAIN
I_MAIN --> R_MAIN

Trainer --> START

' ===== FINDABILITY =====
(Define metadata standards\nF2) as F1 #d0e2ff
(Use Bioschemas training\nprofile\nF2) as F2 #d0e2ff
(Deposit in Zenodo\nassign DOI\nF1/F3) as F3 #cfe8f3
(Register materials in TeSS\nF4) as F4 #d0e2ff

F_MAIN --> F1
F1 --> F2 : extend
F1 --> F3
F3 --> F4

' ===== ACCESSIBILITY =====
(Provide access in the metadata\nHTTPS or API\nA1.1) as A1 #d9f2d9
(Restrict access if needed\nvia LMS authentication\nA1.2) as A2 #d9f2d9
(Ensure metadata remains\naccessible\nA2/F1) as A3 #e2f0d9

A_MAIN --> A1
A1 --> A2 : extend
A2 --> A3

' ===== INTEROPERABILITY =====
(Develop materials using\nGitHub platform\nI1/R) as I1 #fff4cc
(Use community lesson templates:\nCarpentries, ELIXIR\nI2/R) as I2 #fff4cc
(Use FAIR vocabularies via\nFAIRsharing\nI2) as I3 #fff8dc
(Link tools, datasets,\nand assessments via DOI\nI3) as I4 #fdebd0
(For LMS, package content using\nLMS standards\nI3) as I5 #fff8dc

I_MAIN --> I1
I1 --> I2 : include
I2 --> I3 : include
I3 --> I4 : include
I4 --> I5 : extend
F1 --> I3 : extend
' ===== REUSABILITY =====
(Provide clear and\naccessible license\nR1.1) as R1 #f8d7da
(Track provenance with\nrich metadata on GitHub or Zenodo\nR1.2/I3) as R2 #f8d7da
(Version releases via\nGitHub or Zenodo\nR1.2/I3) as R3 #f5c6cb
(Use community and\ndomain standards\nR1.3/I2) as R4 #f5c6cb

R_MAIN --> R1
R1 --> R2
R2 --> R3 : include
R3 --> R4
F1 --> R1 : extend

' ===== USER SIDE =====
(Search materials via TeSS\nF) as U1 #d0e2ff
(Access via Zenodo or LMS\nA) as U2 #d9f2d9
(Reuse following FAIR\nprinciples\nR) as U3 #f8d7da

Trainee --> U1
U1 --> U2
U2 --> U3
Trainer2 --> U3

}

@enduml
